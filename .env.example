# lifeOS — environment configuration
# Copy to .env and edit values

# Auth — REQUIRED for production
# Set a strong passphrase to protect your instance.
# The app will require this passphrase to unlock.
# You can use a plain passphrase or a bcrypt hash (starts with $2b$).
# Generate a bcrypt hash: node -e "console.log(require('bcryptjs').hashSync('your-passphrase', 10))"
AUTH_SECRET=changeme-to-a-strong-passphrase

# Database — path to SQLite database file
DATABASE_PATH=./data/lifeos.db

# Attachments — path to attachment storage (future use)
ATTACHMENTS_PATH=./data/attachments

# Server
PORT=3000
NODE_ENV=development
